# ============== Trading Lab Pro — env mẫu ==============
# Copy file này thành .env và điền giá trị thật. Không commit .env.
# Nếu không có file .env, app sẽ dùng giá trị mặc định trong code (xem core/config.py).

# ---- Ứng dụng ----
APP_NAME=Trading Lab Pro
APP_ENV=development

# ---- Database ----
# SQLite (mặc định, không cần cài PostgreSQL) — file DB tự tạo trong thư mục project
DATABASE_URL=sqlite:///./trading_lab.db
# Hoặc dùng PostgreSQL (khi chạy Docker hoặc production):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trading_lab

# ---- Redis (tùy chọn, dự phòng) ----
REDIS_URL=redis://localhost:6379/0

# ---- Market data ----
# Nguồn giá: cmc (CoinMarketCap) hoặc binance. Mặc định: cmc
# Lưu ý: SIREN chỉ có trên Binance Futures → nếu trade SIREN thì dùng binance
PRICE_SOURCE=cmc
# Bắt buộc khi PRICE_SOURCE=cmc
CMC_API_KEY=your-cmc-api-key

# ---- Binance API (cho đọc giá / giao dịch thật khi bật) ----
# Key và Secret lấy từ Binance: Hồ sơ → API Management. Chỉ điền vào file .env thật, không commit.
# Giới hạn đề xuất: Đọc, Giao dịch Spot & Margin, Giao dịch Futures.
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret

# ---- Lệnh thật Binance Futures (USD-M) ----
# Bật = đánh lệnh thật trên Futures, mỗi lệnh gồm TP và SL. Mặc định: false (paper trading)
ENABLE_LIVE_BINANCE_FUTURES=false
# Testnet: true = testnet.binancefuture.com (xem lệnh tại đó), false = sàn thật (binance.com/futures)
BINANCE_FUTURES_TESTNET=true
# Đòn bẩy (1–125). Áp dụng khi mở lệnh Futures. Mặc định: 20
BINANCE_FUTURES_LEVERAGE=20
# recvWindow (ms) cho signed request — tăng nếu lỗi -1021 Timestamp outside recvWindow. Mặc định: 60000 (60s)
BINANCE_RECV_WINDOW=60000
# Trailing Stop: khi bật, có thể dùng Trailing thay TP cố định. Mặc định: false
BINANCE_USE_TRAILING_STOP=false
# Trailing callback rate % (0.1–10). Mặc định: 1.5
BINANCE_TRAILING_CALLBACK_PCT=1.5
# Chỉ dùng trailing khi regime=high_momentum. Mặc định: true
BINANCE_TRAILING_ONLY_MOMENTUM=true

# ---- AI / LLM (tùy chọn, cho daily reflection) ----
OPENAI_API_KEY=sk-your-openai-api-key-here

# ---- Telegram báo cáo cuối ngày ----
# Token: lấy từ @BotFather. Chat ID: ID nhóm (số âm) hoặc chat riêng (xem docs/operator_manual.md)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ---- Risk & vốn ----
DEFAULT_CAPITAL_USD=1000
DEFAULT_RISK_PCT=0.01
MAX_DAILY_LOSS_PCT=0.03
MAX_CONCURRENT_TRADES=3
# Số lệnh tối đa cho cùng 1 symbol. Mặc định: 1 (không vào thêm)
MAX_POSITIONS_PER_SYMBOL=1
# Vùng giá đẹp (entry ± %), dùng khi cho phép vào thêm lệnh cùng symbol. Mặc định: 0.005 (0.5%)
ENTRY_ZONE_PCT=0.005
# Khi vào thêm cùng symbol: chỉ cho phép nếu tín hiệu từ chiến lược KHÁC. Mặc định: true
ADD_ONLY_DIFFERENT_STRATEGY=true
# Khoảng cách tối thiểu (%) giữa giá thêm và entry lệnh đã mở. Mặc định: 0.003 (0.3%)
MIN_ADD_DISTANCE_PCT=0.003

# ---- Worker: chu kỳ chạy cycle ----
# Giây giữa mỗi lần chạy (10 = 10s, 300 = 5 phút). Tối thiểu 5s để tránh quá tải API. Mặc định: 15
CYCLE_INTERVAL_SECONDS=15

# ---- Trading style & filters ----
# Khung thời gian: "swing" = TP/SL theo % từ entry, có thể nới TP xa. "day" = TP không cách giá hiện tại quá max_tp_pct_above_current. Mặc định: swing
TRADING_STYLE=swing
# Khi trading_style = "day" hoặc > 0: TP long không được cao hơn current_price * (1 + pct). Mặc định: 0 (không giới hạn)
MAX_TP_PCT_ABOVE_CURRENT=0.0
# Chỉ vào long nếu nến 4h gần nhất tăng (close >= open); short nếu nến 4h giảm. Mặc định: false
USE_4H_TREND_FILTER=false
# Đóng chủ động trước thời hạn: 0 = tắt. >0 = đóng mọi vị thế đã giữ quá N giờ. Mặc định: 0
MAX_HOLD_HOURS=0.0
# Đóng long chủ động khi regime = risk_off; short khi regime = high_momentum. Mặc định: false
PROACTIVE_CLOSE_IF_RISK_OFF=false

# ---- AI TP/SL (khi có OpenAI key) ----
# Ưu tiên gợi ý AI cho cập nhật TP/SL (gọi AI trước, dùng kết quả AI nếu có). Mặc định: true
PREFER_AI_SL_TP=true
# Tuổi tối thiểu (phút) trước khi cho AI can thiệp TP/SL. Mặc định: 5.0
AI_SL_TP_MIN_AGE_MINUTES=5.0
# PnL % tối thiểu để cho AI can thiệp TP/SL khi position còn mới. Mặc định: 0.8 (0.8%)
AI_SL_TP_MIN_PNL_PCT=0.8
# Coin biến động mạnh: tuổi tối thiểu (phút) cho AI sớm hơn. Mặc định: 3.0
AI_SL_TP_MIN_AGE_MINUTES_HIGH_VOL=3.0
# Coin biến động mạnh: PnL % tối thiểu cho AI can thiệp. Mặc định: 0.5 (0.5%)
AI_SL_TP_MIN_PNL_PCT_HIGH_VOL=0.5

# ---- Chốt lãi an toàn (Lock profit) ----
# Khi lãi chưa chốt >= số USD này thì hệ thống gợi ý kéo SL lên (long) / xuống (short) để nếu đảo chiều vẫn có lãi. 0 = tắt. Mặc định: 30
LOCK_PROFIT_MIN_USD=30
# SL khi chốt lãi: tối thiểu cách entry buffer % (tránh spread). Mặc định: 0.002 (0.2%)
LOCK_PROFIT_BUFFER_PCT=0.002

# ---- Execution simulator (paper trading) ----
# Phí mô phỏng (basis points). Mặc định: 10 (0.1%)
SIM_FEE_BPS=10
# Slippage mô phỏng (basis points). Mặc định: 5 (0.05%)
SIM_SLIPPAGE_BPS=5
