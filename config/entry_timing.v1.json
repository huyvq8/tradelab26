{
  "enabled": true,
  "apply_to_strategies": ["trend_following", "breakout_momentum"],
  "extended_candle": {
    "enabled": true,
    "body_range_ratio_min": 0.72,
    "range_pct_of_price_min": 0.018,
    "reject_message": "Last 1h candle over-extended (body/range high + wide range); wait for pullback."
  },
  "pullback": {
    "enabled": true,
    "chase_top_pct_of_range": 0.12,
    "require_close_below_prior_high": false,
    "reject_message": "Price chasing candle high without pullback/retest."
  },
  "cooldown": {
    "enabled": true,
    "seconds_between_entries_per_symbol": 900,
    "storage_relative": "storage/entry_cooldown.json"
  },
  "signal_levels": {
    "enabled": true,
    "atr_period": 14,
    "sl_atr_mult": 1.25,
    "tp_atr_mult": 2.0,
    "min_sl_pct": 0.9,
    "max_sl_pct": 3.8,
    "max_tp_pct": 4.0,
    "min_tp_pct": 1.2
  }
}
